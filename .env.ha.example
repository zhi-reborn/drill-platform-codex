# 高可用部署环境变量示例
# 复制为 .env.ha 并修改后使用

# 应用角色：api, worker, all
APP_ROLE=all

# 实例 ID（每个节点必须唯一）
INSTANCE_ID=backend-a

# MySQL 配置
MYSQL_ROOT_PASSWORD=drill123
MYSQL_DATABASE=drill_platform
MYSQL_USER=drill
MYSQL_PASSWORD=drill123
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=drill_platform

# Redis 配置
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# JWT 密钥（生产环境必须修改）
JWT_SECRET=change-me-in-production

# CAS 单点登录
CAS_PUBLIC_URL=
CAS_SERVICE_URL=

# Worker 配置
WORKER_LEASE_TTL=15s
WORKER_RENEW_INTERVAL=5s

# 命令等待超时
COMMAND_WAIT_TIMEOUT=2s

# 登录日志文件（留空则输出到 stdout）
LOGIN_LOG_FILE=
